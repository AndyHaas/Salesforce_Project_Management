<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Portal File Attachments</masterLabel>
    <description
  >Reusable file cards with optional preview, download, and remove. From another LWC use the `files` attribute; in App Builder use Attachments JSON (array of objects with contentDocumentId, optional contentVersionId, title, fileExtension).</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig
      targets="lightning__RecordPage,lightning__AppPage,lightning__HomePage"
    >
            <property
        name="attachmentsJson"
        type="String"
        label="Attachments JSON"
        description='JSON array, e.g. [{"contentDocumentId":"069...","title":"Spec","fileExtension":"pdf"}]'
      />
            <property
        name="showPreview"
        type="Boolean"
        label="Show preview (name link / LEX preview)"
        default="true"
      />
            <property
        name="showDownload"
        type="Boolean"
        label="Show download"
        default="true"
      />
            <property
        name="showDelete"
        type="Boolean"
        label="Show remove"
        default="false"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
