    <decisions>
        <name>Is_Status_Backlog_or_In_Review</name>
        <label>Is Status Backlog or In Review?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Send_Client_Approved_Completed_Task_Email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Status is In Review</defaultConnectorLabel>
        <rules>
            <name>Status_is_In_Backlog</name>
            <conditionLogic>1 OR 2</conditionLogic>
            <conditions>
                <leftValueReference>Get_Approval_Record.Client_Approved_for_Development__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Approval_Record.Submission_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Client Approves Pending</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Client_Approved_Task_Email</targetReference>
            </connector>
            <label>Status is In Backlog</label>
        </rules>
    </decisions>
