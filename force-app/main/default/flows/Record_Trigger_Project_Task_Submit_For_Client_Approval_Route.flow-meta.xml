<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Submission_To_Client_Completion_Review</name>
        <label>Set Submission To Client Completion Review</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Submission_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Client Reviews and QA&apos;s for Completion</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Prior_Submission_Is_In_Progress_PM_Path</name>
        <label>Prior Submission Is In Progress PM Path</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Remap</defaultConnectorLabel>
        <rules>
            <name>Remap_to_Client_Completion_Review</name>
            <conditionLogic>(1 OR 2 OR 3 OR 4) AND 5</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Submission_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Developer Working</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Submission_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Developer Completes Work/Testing</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Submission_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Developer Submits for Approval to Project Manager</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Submission_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Project Manager Reviews and QA&apos;s Developer Work</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Submission_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Project Manager Submits for Client Approval</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Submission_To_Client_Completion_Review</targetReference>
            </connector>
            <label>Remap to Client Completion Review</label>
        </rules>
    </decisions>
    <description>When Submit For Client Approval sets submission to Project Manager Submits for Client Approval but the task was already in the in-review/PM code path (prior submission Developer Working through PM QA), replace the saved value with Client Reviews and QA&apos;s for Completion so one button works for both backlog and completion handoff.</description>
    <environments>Default</environments>
    <interviewLabel>Project Task Submit For Client Approval Route {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Project Task - Submit For Client Approval Route</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Prior_Submission_Is_In_Progress_PM_Path</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Submission_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Project Manager Submits for Client Approval</stringValue>
            </value>
        </filters>
        <object>Project_Task__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
