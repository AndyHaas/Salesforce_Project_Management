    <formulas>
        <name>form_txt_SubmittingUserRole</name>
        <dataType>String</dataType>
        <expression>CASE(
  {!$User.ContactId},
  {!Get_Approval_Record.Project_Manager__c}, &quot;Project Manager&quot;,
  {!Get_Approval_Record.Client_User__c}, &quot;Client&quot;,
  {!Get_Approval_Record.Developer__c}, &quot;Developer&quot;,
