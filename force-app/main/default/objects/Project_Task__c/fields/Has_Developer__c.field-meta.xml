<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Has_Developer__c</fullName>
    <description>Formula field that returns true if Developer__c is populated</description>
    <formula>NOT(ISBLANK(Developer__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Has Developer</label>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
