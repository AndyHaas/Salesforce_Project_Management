<?xml version="1.0" encoding="UTF-8"?>
<ProfilePasswordPolicy xmlns="http://soap.sforce.com/2006/04/metadata">
    <forgotPasswordRedirect>false</forgotPasswordRedirect>
    <lockoutInterval>30</lockoutInterval>
    <maxLoginAttempts>3</maxLoginAttempts>
    <minimumPasswordLength>18</minimumPasswordLength>
    <minimumPasswordLifetime>true</minimumPasswordLifetime>
    <obscure>true</obscure>
    <passwordComplexity>5</passwordComplexity>
    <passwordExpiration>30</passwordExpiration>
    <passwordHistory>10</passwordHistory>
    <passwordQuestion>1</passwordQuestion>
    <profile>Contractor</profile>
</ProfilePasswordPolicy>
